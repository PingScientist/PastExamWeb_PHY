COMPOSE_PROJECT_NAME=pastexam-acceptance-local
ACCEPTANCE_HTTP_PORT=18080

POSTGRES_USER=acceptance
POSTGRES_PASSWORD=acceptance-only
POSTGRES_DB=test_acceptance_empty
ACCEPTANCE_UPGRADE_DB=test_acceptance_upgrade
ACCEPTANCE_TEST_DB=test_acceptance_suite

MINIO_ROOT_USER=acceptance
MINIO_ROOT_PASSWORD=acceptance-only
MINIO_BUCKET_NAME=acceptance-bucket

SECRET_KEY=acceptance-only-secret-key
DEFAULT_ADMIN_NAME=acceptance-admin
DEFAULT_ADMIN_PASSWORD=acceptance-only
DEFAULT_ADMIN_EMAIL=acceptance@example.invalid

BACKEND_IMAGE=pastexam-backend-acceptance:latest
FRONTEND_IMAGE=pastexam-frontend-acceptance:latest
VITE_API_BASE_URL=http://127.0.0.1:18080/api
VITE_SITE_HOSTNAME=http://127.0.0.1:18080
