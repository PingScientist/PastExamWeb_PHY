{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint --ext .js,.ts,.vue src tests",
    "format": "prettier --write .",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "prepare": "cd .. && husky frontend/.husky"
  },
  "dependencies": {
    "@primeuix/themes": "^3.0.0",
    "@tailwindcss/vite": "^4.3.0",
    "@tato30/vue-pdf": "^2.1.0",
    "axios": "^1.17.0",
    "dompurify": "^3.4.8",
    "highlight.js": "^11.11.1",
    "katex": "^0.17.0",
    "marked": "^18.0.5",
    "pdf-lib": "^1.17.1",
    "primeflex": "^4.0.0",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.5",
    "tailwindcss": "^4.3.0",
    "vue": "^3.5.35",
    "vue-eslint-parser": "^10.4.1",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^2.0.0",
    "@playwright/test": "^1.60.0",
    "@primevue/auto-import-resolver": "^4.5.5",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.8",
    "@vue/test-utils": "^2.4.11",
    "eslint": "^10.4.1",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.7",
    "prettier": "3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^7.3.2",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-eslint": "^1.8.1",
    "vite-plugin-sitemap": "^0.8.2",
    "vite-plugin-vue-devtools": "^8.1.2",
    "vitest": "^4.1.8"
  },
  "lint-staged": {
    "*.{js,jsx,vue}": [
      "pnpm exec eslint --ext .js,.ts,.vue src tests",
      "pnpm exec prettier --write ."
    ]
  }
}
